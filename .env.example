# Provider Credentials
OLLAMA_API_KEY=your_api_key_here
GITHUB_KEY=your_api_key_here

# Ollama Settings
OLLAMA_PROVIDER_NAME="ollama"
OLLAMA_PROVIDER_PRETTY_NAME="Ollama"
OLLAMA_HOST=http://localhost:11434
# Comma separated, no spaces, first in list will be default
OLLAMA_MODELS=model1,model2

# Git Setup
GIT_NAME="FirstName LastName"
GIT_EMAIL=your_email

# Container Settings
# Use the format "PHP_VERSION=XY" where XY is the major and minor version number, e.g. "PHP_VERSION=84" for PHP 8.4. Leave empty to not install PHP.
PHP_VERSION=84

# Theme Settings
THEME=default

# Plugin Configuration
ENABLE_DEVCONTAINERS=false
ENABLE_DCP=false

# MCP Server Configuration
ENABLE_INTELLIJ=false
ENABLE_CONTEXT7=false
ENABLE_SHOPIFY_DEV=false
ENABLE_DDG_SEARCH=false
ENABLE_CLICKUP=false
ENABLE_FIGMA=false
ENABLE_FIGMA_DESKTOP=false
ENABLE_SEQUENTIAL_THINKING=false
ENABLE_GSD=false

# Context7 API Key (optional, for authenticated access)
CONTEXT7_API_KEY=

# Figma oauth credentials (required if ENABLE_FIGMA or ENABLE_FIGMA_DESKTOP is true)
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# ClickUp oauth credentials (required if ENABLE_CLICKUP is true)
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_ID_ISSUED_AT=
CLICKUP_ACCESS_TOKEN=
CLICKUP_EXPIRES_AT=
CLICKUP_SCOPE=

# enable/Disable colours in terminal output, set to false if you have issues with colour codes in your terminal
NO_COLOR=false
